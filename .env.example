# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
#
# All 12 variables below are required for the app to build and run.
# Source of truth: every process.env.* reference in src/.

# Supabase — Postgres + Auth + Storage + Realtime
# Project: qglovarewwdpbjbswqmh (West Europe / London)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Cloudinary — signed direct uploads for product images
# Cloud name: direct-desk-solutions, preset: dds_products_signed
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=direct-desk-solutions
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe — Checkout + webhooks
# Use sk_test_/pk_test_/whsec_test_ in dev, sk_live_/pk_live_/whsec_live_ in prod.
# Webhook secret is the signing secret from the registered endpoint, not the API key.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Anthropic — Claude SDK for AI auto-tagging and condition observations
# Model: claude-sonnet-4-6 (see src/lib/ai/anthropic.ts)
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend — transactional email (forward-looking)
# Reserved for order-confirmation emails. Not yet read by code.
RESEND_API_KEY=re_xxx

# Site URL — used for absolute URLs (sitemap, robots, OG, Stripe success_url, JSON-LD)
# Production: https://direct-desk-solutionse.netlify.app
# Future: https://directdesksolutions.com after DNS cutover
NEXT_PUBLIC_SITE_URL=http://localhost:3000
